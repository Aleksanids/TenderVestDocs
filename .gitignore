# Editor / OS noise
.idea/
.vscode/
.DS_Store
Thumbs.db
desktop.ini

# Small synthetic fixtures and process reports are allowed.
!tests/
!tests/fixtures/
!tests/fixtures/**/*.json
!tests/fixtures/**/*.csv
!tests/fixtures/**/*.xlsx
!docs/
!docs/**/*.md
!reports/
!reports/stages/
!reports/stages/**/*.md
!reports/stages/**/*.json
!reports/stages/**/*.txt
